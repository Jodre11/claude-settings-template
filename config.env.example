# Claude Settings Template — Configuration
# Copy to config.env and fill in your values.
# Run ./hydrate.sh to generate config files from templates.

# --- aws sso ---
AWS_PROFILE=               # e.g. claude-code
SSO_START_URL=             # e.g. https://myorg.awsapps.com/start

# --- settings.json ---
# Written automatically by setup-platform.sh — leave blank to skip awsAuthRefresh.
AWS_SSO_REFRESH_PATH=

# --- datadog ---
DATADOG_SITE=              # e.g. datadoghq.com, datadoghq.eu
DATADOG_EXAMPLE_SERVICE=   # e.g. my-api-service

# --- CLAUDE.md ---
DOTFILES_REPO_URL=         # e.g. https://github.com/youruser/dotfiles
