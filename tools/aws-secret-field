#!/usr/bin/env bash
# aws-secret-field - Update a single field in a JSON secret in AWS Secrets Manager.
# Usage: aws-secret-field <field_name> <new_value> --secret-id <id> [options]
#        aws-secret-field <field_name> <new_value> [options]   (if AWS_SECRET_ID is set)
#
# Requires: aws CLI, python3
# Source:   ~/.claude/tools/aws-secret-field (version-controlled)
# Symlink:  ~/.local/bin/aws-secret-field
#
# Options:
#   --secret-id <id>       Secrets Manager secret ID (or set AWS_SECRET_ID)
#   --profile <profile>    AWS CLI profile (or set AWS_PROFILE)
#   --file <path>          Also write the new value to this file (e.g. a Strongbox .secret file)
#
# Environment variables:
#   AWS_SECRET_ID          Default secret ID (overridden by --secret-id)
#   AWS_PROFILE            Default AWS profile (overridden by --profile)
#
# Examples:
#   aws-secret-field oauth_refresh_token "abc123" --secret-id my/secret --profile dev
#   aws-secret-field oauth_refresh_token "abc123" --file path/to/token.secret
#   AWS_SECRET_ID=my/secret aws-secret-field oauth_refresh_token "abc123"

set -euo pipefail

usage() {
    echo "Usage: $(basename "$0") <field_name> <new_value> --secret-id <id> [--profile <profile>] [--file <path>]"
    echo ""
    echo "Set AWS_SECRET_ID and/or AWS_PROFILE environment variables to avoid passing them each time."
    exit 1
}

if [[ $# -lt 2 ]]; then
    usage
fi

FIELD_NAME="$1"
NEW_VALUE="$2"
shift 2

SECRET_ID="${AWS_SECRET_ID:-}"
PROFILE="${AWS_PROFILE:-}"
LOCAL_FILE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --secret-id)
            SECRET_ID="$2"
            shift 2
            ;;
        --profile)
            PROFILE="$2"
            shift 2
            ;;
        --file)
            LOCAL_FILE="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            usage
            ;;
    esac
done

if [[ -z "$SECRET_ID" ]]; then
    echo "Error: --secret-id is required (or set AWS_SECRET_ID)"
    usage
fi

PROFILE_ARGS=()
if [[ -n "$PROFILE" ]]; then
    PROFILE_ARGS=(--profile "$PROFILE")
fi

echo "Fetching current secret: $SECRET_ID"
CURRENT=$(aws secretsmanager get-secret-value \
    --secret-id "$SECRET_ID" \
    "${PROFILE_ARGS[@]}" \
    --query 'SecretString' \
    --output text)

if ! echo "$CURRENT" | python3 -m json.tool > /dev/null 2>&1; then
    echo "Error: secret value is not valid JSON"
    exit 1
fi

FIELD_EXISTS=$(echo "$CURRENT" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print('yes' if sys.argv[1] in d else 'no')
" "$FIELD_NAME")

if [[ "$FIELD_EXISTS" == "no" ]]; then
    echo "Warning: field '$FIELD_NAME' does not exist in the secret. It will be added."
    read -rp "Continue? [y/N] " confirm
    if [[ "$confirm" != [yY] ]]; then
        echo "Aborted."
        exit 0
    fi
fi

export _SECRET_NEW_VALUE="$NEW_VALUE"
UPDATED=$(echo "$CURRENT" | python3 -c "
import os, sys, json
d = json.load(sys.stdin)
d[sys.argv[1]] = os.environ['_SECRET_NEW_VALUE']
print(json.dumps(d))
" "$FIELD_NAME")
unset _SECRET_NEW_VALUE

echo "Updating field '$FIELD_NAME' in secret '$SECRET_ID'..."
aws secretsmanager put-secret-value \
    --secret-id "$SECRET_ID" \
    --secret-string "$UPDATED" \
    "${PROFILE_ARGS[@]}"

echo "Done. Field '$FIELD_NAME' updated in Secrets Manager."

if [[ -n "$LOCAL_FILE" ]]; then
    printf '%s' "$NEW_VALUE" > "$LOCAL_FILE"
    echo "Done. Value written to $LOCAL_FILE"
fi
