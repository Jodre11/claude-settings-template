{
  "env": {
    "AWS_PROFILE": "claude-code",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "SEARXNG_URL": "https://searxng.taild2db48.ts.net"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(playwright-cli *)",
      "Bash(read-only commands)",
      "Bash(jb inspectcode *)",
      "Bash(terraform fmt *)",
      "Bash(mkdir -p /tmp/claude-*)",
      "Bash(cat /tmp/claude-*)",
      "Bash(cat * > /tmp/claude-*)",
      "Bash(rm /tmp/claude-*)",
      "Bash(rm -f /tmp/claude-*)",
      "Bash(rm -rf /tmp/claude-*)",
      "Write(//tmp/claude-**)",
      "Edit(//tmp/claude-**)",
      "Read",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(brew info *)",
      "Bash(grep *)",
      "Bash(whisper-cli *)",
      "WebFetch(domain:community.workday.com)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_evaluate",
      "Bash(dotnet build *)",
      "Bash(dotnet add *)",
      "Bash(dotnet run *)",
      "Bash(curl *)",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_tabs",
      "Bash(dotnet list *)",
      "Bash(dotnet nuget *)",
      "Bash(dotnet package *)",
      "WebFetch(domain:stackoverflow.com)",
      "Bash(rustc --version 2>&1 && cargo --version 2>&1)",
      "Bash(cargo init *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(cargo build *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.npmjs.com)",
      "Bash(npx playwright *)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(jq *)",
      "Bash(cp *)",
      "Bash(command claude *)",
      "Read(~/.claude/commands/**)",
      "Read(~/.claude/skills/**)",
      "Read(~/.claude/agents/**)",
      "Read(~/.claude/plugins/**)",
      "Bash(find ~/.claude/projects -name *.md -o -name *.json)",
      "Bash(command -v jbinspect)",
      "Read(//usr/local/bin/**)",
      "Skill(update-config)",
      "Bash(chmod *)",
      "Bash(~/.claude/hooks/bash-guard.sh)",
      "Bash(python3 *)",
      "Bash(/tmp/test-sanitise.sh)",
      "Bash(tmux *)",
      "Bash(aws sso *)",
      "Bash(aws *)",
      "Bash(md2clip *)",
      "Bash(wc *)",
      "Bash(tail *)",
      "Bash(xxd *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(file *)",
      "Bash(ls *)",
      "Bash(open *)",
      "Read(//Applications/**)"
    ],
    "deny": [
      "Read(~/.strongbox_keyring)",
      "Edit(~/.strongbox_keyring)",
      "Write(~/.strongbox_keyring)",
      "Bash(*strongbox_keyring*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && [ -z \"$CLAUDE_CODE_USE_BEDROCK\" ] && tmux set status-style bg=colour218,fg=black; true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && tmux set -u status-style; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/allow-permissions.sh",
            "timeout": 5,
            "statusMessage": "Checking allowed commands..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking Bash rules..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-mode-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking agent mode..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/allow-write-permissions.sh",
            "timeout": 5,
            "statusMessage": "Checking write permissions..."
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/temp-path-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking temp path..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-review@jodre11-plugins": true,
    "web-search@jodre11-plugins": true,
    "playwright-cli@jodre11-plugins": true,
    "md-to-clipboard@jodre11-plugins": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "jodre11-plugins": {
      "source": {
        "source": "github",
        "repo": "Jodre11/claude-code-plugins"
      }
    }
  },
  "language": "English UK",
  "companyAnnouncements": [
    "Welcome Jodrell."
  ],
  "showThinkingSummaries": true
}
